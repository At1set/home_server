{
	"compilerOptions": {
		"rootDir": "./src",
		"outDir": "./dist",

		"target": "ES2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"noUnusedParameters": true,
		"noUnusedLocals": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": ["src/**/*"]
}
