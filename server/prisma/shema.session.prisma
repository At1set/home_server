model sessions {
  id            String   @id @db.Char(36)
  user_id       String   @db.Char(36)
  refresh_token String   @unique(map: "idx_sessions_token") @db.VarChar(512)
  device_id     String   @db.VarChar(50)
  device_name   String   @db.VarChar(150)
  ip_address    String   @db.VarChar(45)
  expires_at    DateTime @db.Timestamp(0)
  created_at    DateTime @default(now()) @db.Timestamp(0)
  users         users    @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_sessions_users")

  @@unique([user_id, device_id], map: "idx_sessions_user_device")
  @@map("sessions")
}
