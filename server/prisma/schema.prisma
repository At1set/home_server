generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model sessions {
  id            BigInt              @id @default(autoincrement())
  user_id       String              @db.Char(36)
  refresh_token String              @unique(map: "idx_sessions_token") @db.VarChar(255)
  device_id     String              @db.VarChar(50)
  device_name   String              @db.VarChar(150)
  ip_address    String              @db.VarChar(45)
  expires_at    DateTime            @db.Timestamp(0)
  created_at    DateTime            @default(now()) @db.Timestamp(0)
  users         users               @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk_sessions_users")

  @@index([user_id], map: "idx_sessions_user")
}

model users {
  id         String              @id @default(dbgenerated("(uuid())")) @db.Char(36)
  login      String              @unique(map: "idx_users_login") @db.VarChar(50)
  password   String              @db.VarChar(255)
  name       String              @db.VarChar(100)
  role       String              @default("user") @db.VarChar(50)
  created_at DateTime            @default(now()) @db.Timestamp(0)
  sessions   sessions[]
}
